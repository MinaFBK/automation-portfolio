      {
        "parameters": {
          "operation": "executeQuery",
          "query": "INSERT INTO invoices\n  (vendor_name, invoice_number, invoice_date, due_date, currency,\n   subtotal, tax, total, line_items, source_file)\nVALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9::jsonb, $10)",
          "options": {
            "queryReplacement": "={{ [$('Parse & Validate').item.json.data.vendor_name, $('Parse & Validate').item.json.data.invoice_number, $('Parse & Validate').item.json.data.invoice_date, $('Parse & Validate').item.json.data.due_date, $('Parse & Validate').item.json.data.currency, $('Parse & Validate').item.json.data.subtotal, $('Parse & Validate').item.json.data.tax, $('Parse & Validate').item.json.data.total, JSON.stringify($('Parse & Validate').item.json.data.line_items), $('On form submission').item.binary.Invoice.fileName] }}"
          }
        },
