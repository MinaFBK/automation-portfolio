            "mode": "list",
            "cachedResultName": "models/gemini-2.5-flash"
          },
          "text": "You are an invoice data extractor. Read the attached document and return ONLY one valid JSON object — no markdown, no code fences, no commentary — with exactly these keys:\n{\"vendor_name\": string, \"invoice_number\": string, \"invoice_date\": \"YYYY-MM-DD\", \"due_date\": \"YYYY-MM-DD or null\", \"currency\": \"3-letter ISO code\", \"line_items\": [{\"description\": string, \"quantity\": number, \"unit_price\": number, \"amount\": number}], \"subtotal\": number, \"tax\": number, \"total\": number}\nRules: Use null for any field you cannot find; never invent values. Numbers must be plain numbers (no currency symbols or thousands separators). Dates as YYYY-MM-DD; if missing or partial, use null. Output the JSON object and nothing else.",
          "inputType": "binary",
          "binaryPropertyName": "Invoice",
          "options": {}
        },
        "type": "@n8n/n8n-nodes-langchain.googleGemini",
        "typeVersion": 1.2,
        "position": [
          208,
          0
        ],
        "id": "36fee51b-df69-492d-8353-2233222d2da3",
        "name": "Analyze document",
        "retryOnFail": true,
        "maxTries": 3,
        "waitBetweenTries": 5000,
        "credentials": {
          "googlePalmApi": {
            "id": "NMV0LyJzoksUpJMJ",
            "name": "Google Gemini(PaLM) Api account"
          }
        }
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "// Gemini's JSON answer lives at content.parts[0].text for this node\nconst c = $json.content;\nlet raw = (c && c.parts && c.parts[0] && c.parts[0].text) ? c.parts[0].text : ($json.text ?? $json.content ?? '');\nif (typeof raw !== 'string') raw = JSON.stringify(raw);\n\n// Defensive: strip ```json fences / stray prose, keep the outermost {...}\nlet cleaned = raw.trim().replace(/^```(?:json)?/i, '').replace(/```$/, '').trim();\nconst a = cleaned.indexOf('{'), b = cleaned.lastIndexOf('}');\nif (a !== -1 && b !== -1) cleaned = cleaned.slice(a, b + 1);\n\nlet data = null, parseError = null;\ntry { data = JSON.parse(cleaned); } catch (e) { parseError = e.message; }\n\n\nconst errors = [];\nif (parseError) {\n  errors.push('JSON parse failed: ' + parseError);\n} else {\n  for (const k of ['vendor_name','invoice_number','subtotal','tax','total'])\n    if (data[k] === undefined || data[k] === null || data[k] === '') errors.push('missing field: ' + k);\n  for (const k of ['subtotal','tax','total'])\n    if (data[k] !== null && typeof data[k] !== 'number') errors.push(k + ' is not a number');\n  if (!Array.isArray(data.line_items)) errors.push('line_items is not an array');\n  if (['subtotal','tax','total'].every(k => typeof data[k] === 'number') &&\n      Math.abs((data.subtotal + data.tax) - data.total) > 0.01)\n    errors.push('totals do not add up: ' + data.subtotal + ' + ' + data.tax + ' != ' + data.total);\n}\nreturn { valid: errors.length === 0, errors, data };"
        },
        "id": "ae1d0ad0-dd5e-43db-9cce-2b5be688d798",
        "name": "Parse & Validate",
